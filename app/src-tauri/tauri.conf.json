{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clarity",
  "version": "0.4.1",
  "identifier": "com.trevoradelman.clarity",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Clarity",
        "width": 1080,
        "height": 760,
        "minWidth": 860,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/trevadelman/clarity/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ4ODI5OTYyOEU2Q0YwMDcKUldRSDhHeU9ZcG1DU0diNGhUeWhrZXpIckZacFF6UlRLdEg4Mk9CZldWLzd1M1hodXErMXJFOEsK"
    }
  }
}
